{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KnightPrep",
  "version": "1.0.0",
  "identifier": "com.knightprep.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "KnightPrep — Chess Flashcard Trainer",
      "width": 1440, "height": 900,
      "minWidth": 1100, "minHeight": 700,
      "resizable": true, "fullscreen": false,
      "decorations": true, "center": true
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true, "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "windows": { "certificateThumbprint": null, "digestAlgorithm": "sha256", "timestampUrl": "" }
  }
}
